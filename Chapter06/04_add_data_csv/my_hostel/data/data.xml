<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
        <!-- Precisions -->
        <record forcecreate="True" id="decimal_point" model="decimal.precision">
            <field name="name">Rating Value</field>
            <field name="digits">3</field>
        </record>

        <record id="hostel_room_1" model="hostel.room">
            <field name="name"> Hostel Room 01 </field>
            <field name="student_per_room">3</field>
            <field name="room_no">001</field>
        </record>

        <record id="base.main_company" model="res.company">
            <field name="name">VB Group of Hostels</field>
        </record>

        <record id="hostel_hostel_1" model="hostel.hostel">
            <field name="name">Hostel 1</field>
            <field name="hostel_code">H1</field>
            <field name="phone">1234567890</field>
            <field name="mobile">9998999789</field>
            <field name="city">Birmingham</field>
            <field name="country_id" ref="base.uk"/>
        </record>

        <record id="hostel_category_all" model="hostel.category" forcecreate="False">
            <field name="name">All Rooms</field>
        </record>

</odoo>